{
  "name": "travelvault",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "cd backend && php artisan serve",
    "dev:all": "concurrently --kill-others-on-fail --names \"FRONTEND,BACKEND\" --prefix-colors \"cyan,magenta\" \"npm run dev\" \"npm run dev:backend\"",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "npm run build && wrangler dev",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "deploy:cloudflare": "npm run build",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.22.0",
    "ogl": "^1.0.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-dropzone": "^15.0.0",
    "react-hot-toast": "^2.6.0",
    "react-intersection-observer": "^10.0.3",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}
