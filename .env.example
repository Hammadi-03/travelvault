# Frontend API base URL (no trailing slash)
#
# LOCAL DEV — leave empty. The Vite dev server proxies /api/* → Laravel at 127.0.0.1:8000.
# PRODUCTION — must be set to your Laravel API domain BEFORE running `npm run build`.
#   The Cloudflare Worker serves only static assets; there is no request proxy.
#   Without this, all /api/* calls hit Cloudflare's asset server and return 405.
#
VITE_API_URL=https://api.murjanlab.my.id
